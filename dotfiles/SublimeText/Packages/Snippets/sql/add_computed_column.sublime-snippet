<snippet>
    <content><![CDATA[
if not exists (select top(1) 1 from sys.columns where Name = N'${1:column}' and object_id = object_id(N'[${2:schema}].[${3:table}]'))
begin
    alter table [${2:schema}].[${3:table}] add [${1:column}] as (${4:function}) persisted;
end;
go
]]></content>
