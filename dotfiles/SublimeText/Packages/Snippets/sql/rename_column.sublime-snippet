<snippet>
    <content><![CDATA[
if exists (select top(1) 1 from sys.columns where Name = N'${3:old_column}' and object_id = object_id(N'[${1:schema}].[${2:table}]'))
begin
    exec sp_rename '${1:schema}.${2:table}.${3:old_column}', '${4:new_column}', 'COLUMN';
end;
go
]]></content>
