    <content><![CDATA[
delete s
from [dbo].[Setting] s
    inner join [dbo].[SettingDefinition] sd on s.SettingDefinitionID = sd.ID
where sd.SettingName = '${1:name}';

delete [dbo].[SettingDefinition] where SettingName = '${1:name}';
go
]]></content>
