    <content><![CDATA[
if exists (select top(1) 1 from sys.objects where type = N'FN' and name = N'FN_${2:function}' and schema_id = schema_id(N'${1:schema}'))
begin
    drop function [${1:schema}].[FN_${2:function}];
end;
go
]]></content>
